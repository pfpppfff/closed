<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

    <appSettings>
        <!-- 多PLC通讯配置 -->
        <!-- 全局设置 -->
        <add key="S7_PlcCount" value="2" />
        <add key="S7_DefaultPlcId" value="PLC1" />
        <add key="S7_GlobalCacheExpirationMs" value="100" />

        <!-- PLC1 配置 (S7-1500, 192.168.2.10) -->
        <add key="S7_Plc1_Id" value="PLC1" />
        <add key="S7_Plc1_Name" value="主PLC" />
        <add key="S7_Plc1_CpuType" value="S71500" />
        <add key="S7_Plc1_IpAddress" value="192.168.2.10" />
        <add key="S7_Plc1_Rack" value="0" />
        <add key="S7_Plc1_Slot" value="1" />
        <add key="S7_Plc1_ConnectionTimeout" value="5000" />
        <add key="S7_Plc1_HeartbeatInterval" value="5000" />
        <add key="S7_Plc1_AutoReconnect" value="true" />
        <add key="S7_Plc1_ReconnectInterval" value="3000" />
        <add key="S7_Plc1_MaxReconnectAttempts" value="5" />
        <add key="S7_Plc1_Enabled" value="true" />

        <!-- PLC2 配置 (S7-1500, 192.168.2.11) -->
        <add key="S7_Plc2_Id" value="PLC2" />
        <add key="S7_Plc2_Name" value="副PLC" />
        <add key="S7_Plc2_CpuType" value="S71500" />
        <add key="S7_Plc2_IpAddress" value="192.168.2.11" />
        <add key="S7_Plc2_Rack" value="0" />
        <add key="S7_Plc2_Slot" value="1" />
        <add key="S7_Plc2_ConnectionTimeout" value="5000" />
        <add key="S7_Plc2_HeartbeatInterval" value="5000" />
        <add key="S7_Plc2_AutoReconnect" value="true" />
        <add key="S7_Plc2_ReconnectInterval" value="3000" />
        <add key="S7_Plc2_MaxReconnectAttempts" value="5" />
        <add key="S7_Plc2_Enabled" value="true" />
    </appSettings>
</configuration>